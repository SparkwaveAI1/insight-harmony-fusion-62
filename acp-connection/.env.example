# PersonaAI ACP Connection — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git

# ACP Configuration
# Get your API key from: https://console.game.virtuals.io/
ACP_API_KEY=your-acp-api-key-here

# Wallet Configuration
# The private key should NOT include the 0x prefix
AGENT_WALLET_PRIVATE_KEY=your-wallet-private-key
AGENT_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: Custom RPC URL
# RPC_URL=

# ACP Environment: 'sandbox' or 'mainnet'
ACP_ENVIRONMENT=sandbox

# PersonaAI Job Execution Webhook
JOB_EXECUTION_WEBHOOK=https://your-project.supabase.co/functions/v1/acp-job-execute
