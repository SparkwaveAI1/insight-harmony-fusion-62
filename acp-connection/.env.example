# ACP Configuration
# Get your API key from: https://console.game.virtuals.io/
ACP_API_KEY=your_acp_api_key_here

# Wallet Configuration
# The private key should NOT include the 0x prefix
AGENT_WALLET_PRIVATE_KEY=your_whitelisted_wallet_private_key
AGENT_WALLET_ADDRESS=0xYourWhitelistedWalletAddress

# Optional: Custom RPC URL for gas fee estimates
# Recommended for high-volume agents to avoid rate limiting
# RPC_URL=https://your-custom-rpc-endpoint

# ACP Environment
# Options: 'sandbox' (for testing) or 'mainnet' (for production)
ACP_ENVIRONMENT=sandbox

# PersonaAI Job Execution Webhook
# This is the edge function that processes incoming jobs
JOB_EXECUTION_WEBHOOK=https://wgerdrdsuusnrdnwwelt.supabase.co/functions/v1/acp-job-execute

# Legacy variables (kept for reference, not used in new SDK)
# AGENT_ENTITY_ID=your_agent_entity_id
# WHITELISTED_WALLET_ADDRESS=your_whitelisted_wallet
# WHITELISTED_WALLET_PRIVATE_KEY=your_private_key
